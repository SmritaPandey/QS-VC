# QS-VC Production Environment Variables
# Copy this file to .env.production and fill in values

# Domain
DOMAIN=meet.yourdomain.com

# Database
POSTGRES_DB=qsvc
POSTGRES_USER=qsvc
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS

# TURN Server
TURN_SECRET=CHANGE_ME_TURN_SECRET
SFU_ANNOUNCED_IP=YOUR_SERVER_PUBLIC_IP

# MinIO / S3
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# CORS
CORS_ORIGINS=https://meet.yourdomain.com
