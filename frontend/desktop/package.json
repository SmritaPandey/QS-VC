{
    "name": "@qsvc/desktop",
    "version": "0.1.0",
    "private": true,
    "description": "QS-VC Desktop Client (Electron)",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc",
        "start": "electron .",
        "dev": "tsc && electron .",
        "package:win": "electron-builder --win",
        "package:mac": "electron-builder --mac",
        "package:linux": "electron-builder --linux"
    },
    "build": {
        "appId": "com.qsvc.desktop",
        "productName": "QS-VC",
        "directories": {
            "output": "release"
        },
        "win": {
            "target": "nsis",
            "icon": "assets/icon.ico"
        },
        "mac": {
            "target": "dmg",
            "icon": "assets/icon.icns",
            "category": "public.app-category.video"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "icon": "assets/icon.png",
            "category": "Network"
        }
    },
    "dependencies": {
        "electron-updater": "^6.0.0"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.0.0",
        "typescript": "^5.3.0"
    }
}