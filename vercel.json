{
    "version": 2,
    "buildCommand": "npm ci && cd frontend/web && npx vite build",
    "outputDirectory": "frontend/web/dist",
    "installCommand": "npm ci",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}